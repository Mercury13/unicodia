<?xml version="1.0" encoding="utf-8"?>
<ut type="full-transl">
 <info>
  <orig lang="en" fname="en.uorig" />
  <transl lang="cn" pseudoloc="false" />
 </info>
 <file name="lang.ini" idless="false">
  <format name="ini">
   <text-format bom="false" line-break="crlf" />
   <text-escape line-break-mode="c-lf" space-escape="bare" />
   <multitier separator="." />
  </format>
  <group id="Common">
   <group id="Mon">
    <text id="1">
     <orig>January {1}</orig>
     <transl>{1} 年 1 月</transl>
    </text>
    <text id="2">
     <orig>February {1}</orig>
     <transl>{1} 年 2 月</transl>
    </text>
    <text id="3">
     <orig>March {1}</orig>
     <transl>{1} 年 3 月</transl>
    </text>
    <text id="4">
     <orig>April {1}</orig>
     <transl>{1} 年 4 月</transl>
    </text>
    <text id="5">
     <orig>May {1}</orig>
     <transl>{1} 年 5 月</transl>
    </text>
    <text id="6">
     <orig>June {1}</orig>
     <transl>{1} 年 6 月</transl>
    </text>
    <text id="7">
     <orig>July {1}</orig>
     <transl>{1} 年 7 月</transl>
    </text>
    <text id="8">
     <orig>August {1}</orig>
     <transl>{1} 年 8 月</transl>
    </text>
    <text id="9">
     <orig>September {1}</orig>
     <transl>{1} 年 9 月</transl>
    </text>
    <text id="10">
     <orig>October {1}</orig>
     <transl>{1} 年 10 月</transl>
    </text>
    <text id="11">
     <orig>November {1}</orig>
     <transl>{1} 年 11 月</transl>
    </text>
    <text id="12">
     <orig>December {1}</orig>
     <transl>{1} 年 12 月</transl>
    </text>
   </group>
   <group id="Favs">
    <text id="Add">
     <orig>Added to Favourites</orig>
     <transl>已添加到收藏夹</transl>
    </text>
    <text id="Rem">
     <orig>Removed from Favourites</orig>
     <transl>从收藏夹中移除</transl>
    </text>
   </group>
   <text id="Copied">
    <orig>Copied</orig>
    <transl>已复制</transl>
   </text>
  </group>
  <group id="Dating">
   <au-cmt>Strings for script dates (1234, 11th century, etc)</au-cmt>
   <group id="Century">
    <au-cmt>Strings for centuries from 1st to 20th.</au-cmt>
    <text id="1">
     <orig>1st</orig>
     <transl>1</transl>
    </text>
    <text id="2">
     <orig>2nd</orig>
     <transl>2</transl>
    </text>
    <text id="3">
     <orig>3rd</orig>
     <transl>3</transl>
    </text>
    <text id="4">
     <orig>4th</orig>
     <transl>4</transl>
    </text>
    <text id="5">
     <orig>5th</orig>
     <transl>5</transl>
    </text>
    <text id="6">
     <orig>6th</orig>
     <transl>6</transl>
    </text>
    <text id="7">
     <orig>7th</orig>
     <transl>7</transl>
    </text>
    <text id="8">
     <orig>8th</orig>
     <transl>8</transl>
    </text>
    <text id="9">
     <orig>9th</orig>
     <transl>9</transl>
    </text>
    <text id="10">
     <orig>10th</orig>
     <transl>10</transl>
    </text>
    <text id="11">
     <orig>11th</orig>
     <transl>11</transl>
    </text>
    <text id="12">
     <orig>12th</orig>
     <transl>12</transl>
    </text>
    <text id="13">
     <orig>13th</orig>
     <transl>13</transl>
    </text>
    <text id="14">
     <orig>14th</orig>
     <transl>14</transl>
    </text>
    <text id="15">
     <orig>15th</orig>
     <transl>15</transl>
    </text>
    <text id="16">
     <orig>16th</orig>
     <transl>16</transl>
    </text>
    <text id="17">
     <orig>17th</orig>
     <transl>17</transl>
    </text>
    <text id="18">
     <orig>18th</orig>
     <transl>18</transl>
    </text>
    <text id="19">
     <orig>19th</orig>
     <transl>19</transl>
    </text>
    <text id="20">
     <orig>20th</orig>
     <transl>20</transl>
    </text>
   </group>
   <group id="Name">
    <au-cmt>
     <p>$ = makeshift substitution char</p>
     <p>Range = “somewhere in 1234–1357”, not “throughout 1234–1357”</p>
     <p>All start with small letters</p>
    </au-cmt>
    <text id="YBc">
     <orig>$ BC</orig>
     <transl>公元前 $</transl>
    </text>
    <text id="YBefore">
     <orig>before $</orig>
     <transl>在 $ 之前</transl>
    </text>
    <text id="YBeforeBc">
     <orig>before $ BC</orig>
     <au-cmt>Test: CJK ideographs, that’s probably all</au-cmt>
     <transl>在公元前 $ 之前</transl>
    </text>
    <text id="YApprox">
     <orig>≈$</orig>
     <transl>约 $</transl>
    </text>
    <text id="YApproxBc">
     <orig>≈$ BC</orig>
     <transl>约公元前 $</transl>
    </text>
    <text id="Decade">
     <orig>$s</orig>
     <transl>$ 年代</transl>
    </text>
    <text id="Century">
     <orig>$ century</orig>
     <transl>$ 世纪</transl>
    </text>
    <text id="CenturyBc">
     <orig>$ century BC</orig>
     <transl>公元前 $ 世纪</transl>
    </text>
    <text id="Unknown">
     <orig>unknown</orig>
     <transl>未知</transl>
    </text>
   </group>
   <group id="StdComment">
    <au-cmt>
     <p>Standard comments for script dates</p>
     <p></p>
    </au-cmt>
    <text id="FirstInsc">
     <orig>the first known inscription</orig>
     <transl>最早的文字记载</transl>
    </text>
    <text id="ModernForm">
     <orig>in modern form</orig>
     <transl>现代形式</transl>
    </text>
    <text id="MaybeEarlier">
     <orig>maybe earlier</orig>
     <transl>可能更早</transl>
    </text>
   </group>
  </group>
  <group id="Prop">
   <group id="Head">
    <text id="NonChar">
     <orig>Non-character</orig>
     <au-cmt>Test: FFFF (go to FFFD, then manually)</au-cmt>
     <transl>非字符</transl>
    </text>
    <text id="Empty">
     <orig>Vacant position</orig>
     <au-cmt>Test: 1st empty is in Greek+Coptic</au-cmt>
     <transl>空位</transl>
    </text>
    <text id="Block">
     <orig>Block info</orig>
     <au-cmt>Test: any special block (e.g. Latin 1)</au-cmt>
     <transl>区块信息</transl>
    </text>
    <text id="Script">
     <orig>Script info</orig>
     <au-cmt>Test: any normal block (e.g. Deva, Hebr…)</au-cmt>
     <transl>文字信息</transl>
    </text>
    <text id="Control">
     <orig>About control characters</orig>
     <au-cmt>Test: control chars are above fold</au-cmt>
     <transl>关于控制字符</transl>
    </text>
    <text id="DefIgn">
     <orig>Default-ignorable character</orig>
     <au-cmt>Test: CGJ, Tags…</au-cmt>
     <transl>默认忽略字符</transl>
    </text>
    <text id="Emoji16">
     <orig>Graphic &lt;a {1}&gt;emoji&lt;/a&gt; requires &lt;a {2}&gt;U+FE0F&lt;/a&gt; (=VS16)</orig>
     <au-cmt>
      <p>{1}=misc props of &lt;a&gt;, do not forget</p>
      <p>Test: Misc symbols (U+2600)</p>
     </au-cmt>
     <transl>图形 &lt;a {1}&gt;表情符号&lt;/a&gt; 需要 &lt;a {2}&gt;U+FE0F&lt;/a&gt;（=VS16）</transl>
    </text>
    <text id="SuttonNoFill">
     <orig>No fills and rotations</orig>
     <au-cmt>Test: some Sutton chars, eg U+1D916 or 17</au-cmt>
     <transl>无填充和旋转</transl>
    </text>
    <text id="NChars">
     <orig>{1|one=# character|many=# characters}</orig>
     <au-cmt>UNUSED, NChars2 instead</au-cmt>
     <transl>{1} 个字符</transl>
    </text>
    <text id="NChars2">
     <orig>{1} ({2|one=# character|many=# characters})</orig>
     <au-cmt>
      <p>{1} = header</p>
      <p>{2} = # of characters</p>
      <p>Test: almost every header of pop-up window: Control, Latin, blocks…</p>
     </au-cmt>
     <transl>{1}（{2} 个字符）</transl>
    </text>
    <text id="NoHent">
     <orig>without &lt;a {1} &gt;Hentaigana&lt;/a&gt;</orig>
     <au-cmt>
      <p>UNUSED and kept for that Japanese translator</p>
      <p>{1} = additional technical tags (e.g. href, style)</p>
      <p>Test: Hiragana</p>
     </au-cmt>
     <transl>不含 &lt;a {1} &gt;变体假名&lt;/a&gt;</transl>
    </text>
    <text id="NoHent3">
     <orig>{1} ({2|one=# character|many=# characters} without &lt;a {3} &gt;Hentaigana&lt;/a&gt;)</orig>
     <au-cmt>
      <p>{1} = header</p>
      <p>{2} = # of characters</p>
      <p>{3} = additional technical tags (e.g. href, style)</p>
      <p>Test: Hiragana</p>
     </au-cmt>
     <transl>{1} ({2} 个字符 不含 &lt;a {3} &gt;变体假名&lt;/a&gt;)</transl>
    </text>
    <text id="Comp">
     <orig>String content</orig>
     <transl>文本内容</transl>
    </text>
    <text id="Uc">
     <orig>Unicode {1}</orig>
     <transl>Unicode {1}</transl>
    </text>
    <text id="Em">
     <orig>Emoji {1}</orig>
     <transl>表情符号 {1}</transl>
    </text>
    <text id="EqEm">
     <orig>=emoji {1}, </orig>
     <transl>= 表情符号 {1}，</transl>
    </text>
    <text id="NewBlk">
     <orig>New blocks</orig>
     <transl>新区块</transl>
    </text>
    <text id="AffBlk">
     <orig>Affects blocks</orig>
     <au-cmt>Test: select Phags-Pa, click “?”</au-cmt>
     <transl>关联的区块</transl>
    </text>
   </group>
   <group id="Deprec">
    <text id="0">
     <orig>&lt;a {1}&gt;Deprecated character&lt;/a&gt;</orig>
     <au-cmt>Unused right now, but may appear in newer Unicode</au-cmt>
     <transl>&lt;a {1}&gt;弃用字符&lt;/a&gt;</transl>
    </text>
    <text id="1">
     <orig>&lt;a {1}&gt;Deprecated character&lt;/a&gt;, used to revert to default state</orig>
     <au-cmt>Example: 206B</au-cmt>
     <transl>&lt;a {1}&gt;弃用字符&lt;/a&gt;，用于恢复默认状态</transl>
    </text>
    <text id="Ins">
     <orig>&lt;a {1}&gt;Deprecated character&lt;/a&gt;, use {2} instead</orig>
     <au-cmt>Example: 17A3</au-cmt>
     <transl>&lt;a {1}&gt;弃用字符&lt;/a&gt;，使用 {2} 替代</transl>
    </text>
    <text id="Ins2">
     <orig>&lt;a {1}&gt;Deprecated character&lt;/a&gt;, use {2} or {3} instead</orig>
     <au-cmt>Only 2329, 232A</au-cmt>
     <transl>&lt;a {1}&gt;弃用字符&lt;/a&gt;，使用 {2} 或 {3} 替代</transl>
    </text>
    <text id="2">
     <orig>&lt;a {1}&gt;Deprecated character&lt;/a&gt;, use other bidirectional mechanisms instead</orig>
     <au-cmt>Only 206A</au-cmt>
     <transl>&lt;a {1}&gt;弃用字符&lt;/a&gt;，使用其他双向机制替代</transl>
    </text>
    <text id="3">
     <orig>&lt;a {1}&gt;Deprecated character&lt;/a&gt;, use specific Arabic presentation forms instead</orig>
     <au-cmt>Only 206D</au-cmt>
     <transl>&lt;a {1}&gt;弃用字符&lt;/a&gt;，使用特定阿拉伯呈现形式替代</transl>
    </text>
    <text id="4">
     <orig>&lt;a {1}&gt;Deprecated character&lt;/a&gt;, use 0660…69 and other national digits</orig>
     <au-cmt>Only 206E</au-cmt>
     <transl>&lt;a {1}&gt;弃用字符&lt;/a&gt;，使用 0660…0669 和其他的国家数字</transl>
    </text>
    <text id="5">
     <orig>&lt;a {1}&gt;Deprecated character&lt;/a&gt;, use application-level protocols</orig>
     <au-cmt>Only E0001</au-cmt>
     <transl>&lt;a {1}&gt;弃用字符&lt;/a&gt;，使用应用层协议</transl>
    </text>
   </group>
   <group id="Bidi">
    <group id="DIR">
     <au-cmt>Test: Explicit chars in GenPunct</au-cmt>
     <text id="Name">
      <orig>Direction tag</orig>
      <transl>方向标记</transl>
     </text>
     <text id="Short">
      <orig>Direction tag</orig>
      <transl>方向标记</transl>
     </text>
     <text id="Text">
      <orig>
       <p>Format characters that correct operation of Unicode bidirectional algorithm.</p>
       <p />
       <p>Strictly saying, each of these characters is a separate class in bidirectional algorithm, but for non-programmers it’s enough to know: these are direction tags.</p>
      </orig>
      <transl>
       <p>这些格式字符的作用是用来修正 Unicode 双向算法的处理方式。</p>
       <p />
       <p>严格来讲，它们在算法中各自代表一个独立的分类，但如果你不是程序员，只要知道它们是用于控制方向的标记就够了。</p>
      </transl>
     </text>
    </group>
    <group id="AL">
     <au-cmt>Test: Any Arabic letter</au-cmt>
     <text id="Name">
      <orig>Arabic letter</orig>
      <transl>阿拉伯字母</transl>
     </text>
     <text id="Short">
      <orig>Arabic letter</orig>
      <transl>阿拉伯字母</transl>
     </text>
     <text id="Text">
      <orig>Written right to left. There are some subtle rules related to European numbers.</orig>
      <transl>从右向左书写。涉及欧洲数字时有一些微妙规则。</transl>
     </text>
    </group>
    <group id="AN">
     <au-cmt>
      <p>Arabic Number</p>
      <p>Test: Arabic digits (0660…), Rumi (10E60)</p>
     </au-cmt>
     <text id="Name">
      <orig>Arabic number</orig>
      <transl>阿拉伯数字</transl>
     </text>
     <text id="Short">
      <orig>Arabic number</orig>
      <transl>阿拉伯数字</transl>
     </text>
     <text id="Text">
      <orig>Written right to left. There are some subtle rules related no nesting levels.</orig>
      <transl>从右向左书写。涉及嵌套层级时有一些微妙规则。</transl>
     </text>
    </group>
    <group id="B">
     <au-cmt>
      <p>Paragraph Separator</p>
      <p>Test: CR, LF and a few more</p>
     </au-cmt>
     <text id="Name">
      <orig>Paragraph separator</orig>
      <transl>段落分隔符</transl>
     </text>
     <text id="Short">
      <orig>Paragraph separator</orig>
      <transl>段落分隔符</transl>
     </text>
     <text id="Text">
      <orig>Every paragraph is processed separately with bidirectional algorithm.</orig>
      <transl>每一段落都会被单独处理，使用双向算法。</transl>
     </text>
    </group>
    <group id="BN">
     <au-cmt>
      <p>Boundary Neutral</p>
      <p>Test: most controls</p>
     </au-cmt>
     <text id="Name">
      <orig>Boundary neutral</orig>
      <transl>边界中立</transl>
     </text>
     <text id="Short">
      <orig>Boundary neutral</orig>
      <transl>边界中立</transl>
     </text>
     <text id="Text">
      <orig>
       <p>[[pt:control|Control characters]], joiners and [[pk:E0000|tags]] that have no graphic representation.</p>
       <p />
       <p>See [[pt:graphic|graphic character]].</p>
      </orig>
      <transl>
       <p>没有图形表示的 [[pt:control|控制字符]], 连接符和 [[pk:E0000|标签]]。</p>
       <p />
       <p>另见 [[pt:graphic|图形字符]]。</p>
      </transl>
     </text>
    </group>
    <group id="CS">
     <au-cmt>
      <p>Common Separator</p>
      <p>Test: ,.</p>
     </au-cmt>
     <text id="Name">
      <orig>Common separator</orig>
      <transl>通用分隔符</transl>
     </text>
     <text id="Short">
      <orig>Common separator</orig>
      <transl>通用分隔符</transl>
     </text>
     <text id="Text">
      <orig>When appear in European or Arabic number, these characters become its part.</orig>
      <transl>当出现在欧洲或阿拉伯数字中时，这些字符会成为其一部分。</transl>
     </text>
    </group>
    <group id="EN">
     <au-cmt>
      <p>European Number</p>
      <p>Test: 012…</p>
     </au-cmt>
     <text id="Name">
      <orig>European number</orig>
      <transl>欧洲数字</transl>
     </text>
     <text id="Short">
      <orig>European number</orig>
      <transl>欧洲数字</transl>
     </text>
     <text id="Text">
      <orig>Written left to right. There are subtle rules related to Arabic text.</orig>
      <transl>从左向右书写。涉及阿拉伯文本时有一些微妙规则。</transl>
     </text>
    </group>
    <group id="ES">
     <au-cmt>
      <p>European Separator</p>
      <p>Test: +-</p>
     </au-cmt>
     <text id="Name">
      <orig>European separator</orig>
      <transl>欧洲分隔符</transl>
     </text>
     <text id="Short">
      <orig>European separator</orig>
      <transl>欧洲分隔符</transl>
     </text>
     <text id="Text">
      <orig>+ and − characters inside a European number become its part. ± character is outside of this class.</orig>
      <transl>+ 和 - 字符在欧洲数字中成为其一部分。± 字符不属于此类。</transl>
     </text>
    </group>
    <group id="ET">
     <au-cmt>
      <p>European Terminator</p>
      <p>Test: #$°</p>
     </au-cmt>
     <text id="Name">
      <orig>European terminator</orig>
      <transl>欧洲终结符</transl>
     </text>
     <text id="Short">
      <orig>European terminator</orig>
      <transl>欧洲终结符</transl>
     </text>
     <text id="Text">
      <orig>Currency and other characters that commonly appear near numbers. When near a European number, these characters become its part.</orig>
      <transl>货币和其他通常出现在数字附近的字符。靠近欧洲数字时，这些字符成为其一部分。</transl>
     </text>
    </group>
    <group id="L">
     <au-cmt>Test: ABC…</au-cmt>
     <text id="Name">
      <orig>Left-to-right</orig>
      <transl>从左至右</transl>
     </text>
     <text id="Short">
      <orig>→</orig>
      <transl>→</transl>
     </text>
     <text id="Text">
      <orig>Latin, Cyrillic and other scripts written left-to-right. As [[ps:Hani|CJK ideographs]] are the most numerous part of Unicode, it is the pargest class.</orig>
      <transl>拉丁文、西里尔文和其他从左至右书写的体系。由于 [[ps:Hani|中日韩表意文字]] 是 Unicode 中数量最多的部分，因此这是最大的类别。</transl>
     </text>
    </group>
    <group id="NSM">
     <au-cmt>
      <p>Nonspacing Mark</p>
      <p>Test: any combining umlaut</p>
     </au-cmt>
     <text id="Name">
      <orig>Non-spacing mark</orig>
      <transl>不占位标记</transl>
     </text>
     <text id="Short">
      <orig>Non-spacing mark</orig>
      <transl>不占位标记</transl>
     </text>
     <text id="Text">
      <orig>Non-spacing and enclosing combining marks. Writing direction is borrowed from base character.</orig>
      <transl>不占位和包围组合标记。书写方向继承自基础字符。</transl>
     </text>
    </group>
    <group id="ON">
     <au-cmt>Test: !"…</au-cmt>
     <text id="Name">
      <orig>Other neutral</orig>
      <transl>其他中立字符</transl>
     </text>
     <text id="Short">
      <orig>Other neutral</orig>
      <transl>其他中立字符</transl>
     </text>
     <text id="Text">
      <orig>Adapts to direction of surrounding text.</orig>
      <transl>适应周围文本的方向。</transl>
     </text>
    </group>
    <group id="NM">
     <au-cmt>Test: most braces, e.g. ()</au-cmt>
     <text id="Name">
      <orig>Mirroring neutral</orig>
      <transl>镜像中立</transl>
     </text>
     <text id="Short">
      <orig>Mirroring neutral</orig>
      <transl>镜像中立</transl>
     </text>
     <text id="Text">
      <orig>Parentheses and other similar characters are mirrored. All these characters are neutral, as they adapt to direction of surrounding text.</orig>
      <transl>括号和其他类似字符会镜像显示。所有这些字符都是中性的，因为它们适应周围文本的方向。</transl>
     </text>
    </group>
    <group id="R">
     <au-cmt>Test: Hebrew</au-cmt>
     <text id="Name">
      <orig>Right-to-left</orig>
      <transl>从右至左</transl>
     </text>
     <text id="Short">
      <orig>←</orig>
      <transl>←</transl>
     </text>
     <text id="Text">
      <orig>
       <p>[[ps:Hebr|Hebrew]] and historical scripts of Middle East.</p>
       <p />
       <p>[[pb:AL|Arabic letters]] behave differently with European numbers and comprise a separate category.</p>
      </orig>
      <transl>
       <p>[[ps:Hebr|希伯来文字]] 和中东的历史书写体系。</p>
       <p />
       <p>[[pb:AL|阿拉伯字母]] 与欧洲数字处理方式不同，并构成一个单独的类别。</p>
      </transl>
     </text>
    </group>
    <group id="S">
     <au-cmt>
      <p>Segment Separator</p>
      <p>Test: 09, 0B, 1F</p>
     </au-cmt>
     <text id="Name">
      <orig>Segment separator</orig>
      <transl>段落分隔符</transl>
     </text>
     <text id="Short">
      <orig>Segment separator</orig>
      <transl>段落分隔符</transl>
     </text>
     <text id="Text">
      <orig>Three control characters: 09 (tabulation), 0B (vertical tabulation), 1F (separator 1).</orig>
      <transl>三个控制字符：09（制表符）、0B（垂直制表符）、1F（分隔符 1）。</transl>
     </text>
    </group>
    <group id="WS">
     <au-cmt>
      <p>Whitespace</p>
      <p>Test: FF, space</p>
     </au-cmt>
     <text id="Name">
      <orig>Whitespace</orig>
      <transl>空白符</transl>
     </text>
     <text id="Short">
      <orig>Whitespace</orig>
      <transl>空白符</transl>
     </text>
     <text id="Text">
      <orig>
       <p>Neutral. There are subtle rules regarding text formatting with spaces.</p>
       <p />
       <p>See also [[pt:space|space]].</p>
      </orig>
      <transl>
       <p>中性。涉及空格的文本格式存在一些微妙规则。</p>
       <p />
       <p>另见 [[pt:space|空格]]。</p>
      </transl>
     </text>
    </group>
   </group>
   <group id="Num">
    <text id="Digit">
     <orig>Digit</orig>
     <au-cmt>Test: 0…9</au-cmt>
     <transl>数字</transl>
    </text>
    <text id="SpecDigit">
     <orig>Special digit</orig>
     <au-cmt>Test: ¹²³</au-cmt>
     <transl>特殊数字</transl>
    </text>
    <text id="Number">
     <orig>Number</orig>
     <au-cmt>Test: ½⅓¼</au-cmt>
     <transl>数值</transl>
    </text>
    <text id="Or">
     <orig>{1} or {2}</orig>
     <au-cmt>e.g. 5146 — million or trillion depending on language</au-cmt>
     <transl>{1} 或 {2}</transl>
    </text>
    <text id="CjkRare">
     <orig>CJK number (rarely)</orig>
     <transl>中日韩数字（罕见）</transl>
    </text>
    <text id="CjkAccount">
     <orig>CJK number (anti-forgery)</orig>
     <transl>中日韩数字（防伪）</transl>
    </text>
    <text id="CjkZhuang">
     <orig>Zhuang number</orig>
     <transl>壮族数字</transl>
    </text>
    <text id="CjkVietnamese">
     <orig>Vietnamese number</orig>
     <transl>越南数字</transl>
    </text>
    <text id="CjkTay">
     <orig>Tay number</orig>
     <transl>岱依族数字</transl>
    </text>
    <text id="CjkZhuangTay">
     <orig>Zhuang/Tay number</orig>
     <transl>壮族/岱依族数字</transl>
    </text>
   </group>
   <group id="Input">
    <text id="Bullet">
     <orig>Input</orig>
     <au-cmt>Test: any char with alt input</au-cmt>
     <transl>输入</transl>
    </text>
    <text id="Birman">
     <orig>Birman</orig>
     <au-cmt>
      <p>Means Ilya Birman’s typography layout</p>
      <p>Test: U+011B both Alt code and Birman</p>
     </au-cmt>
     <transl>Birman 键盘布局</transl>
    </text>
    <text id="AltCode">
     <orig>Alt code</orig>
     <au-cmt>Test: U+011B both Alt code and Birman</au-cmt>
     <transl>Alt 码</transl>
    </text>
    <text id="Sometimes">
     <orig>sometimes {1}</orig>
     <au-cmt>Test: Tab U+09</au-cmt>
     <transl>有时 {1}</transl>
    </text>
    <text id="Twice">
     <orig>twice {1}</orig>
     <au-cmt>Test: combining acute</au-cmt>
     <transl>两次 {1}</transl>
    </text>
    <text id="Space">
     <orig>Space</orig>
     <au-cmt>Test: NBSP U+00A0</au-cmt>
     <transl>空格</transl>
    </text>
   </group>
   <group id="Bullet">
    <text id="EngTech">
     <orig>Technical name</orig>
     <au-cmt>
      <p>English — Technical</p>
      <p>Other languages — maybe English</p>
      <p>Test: block info</p>
     </au-cmt>
     <transl>技术名称</transl>
    </text>
    <text id="Range">
     <orig>Range</orig>
     <au-cmt>test: block info</au-cmt>
     <transl>范围</transl>
    </text>
    <text id="VerAppear">
     <orig>Appeared in version</orig>
     <au-cmt>Test: block info</au-cmt>
     <transl>引入版本</transl>
    </text>
    <text id="NonChars">
     <orig>Non-characters</orig>
     <au-cmt>Test: any block with nonchars (e.g. Specials)</au-cmt>
     <transl>非字符</transl>
    </text>
    <text id="Empty">
     <orig>Vacant positions</orig>
     <au-cmt>Test: Any block with empty places: Specials, Greek/Coptic…</au-cmt>
     <transl>空位</transl>
    </text>
    <text id="VerFilled">
     <orig>Filled in version</orig>
     <au-cmt>Test: Any full block (e.g. ASCII)</au-cmt>
     <transl>补全版本</transl>
    </text>
    <text id="Version">
     <orig>Unicode version</orig>
     <au-cmt>Test: any char</au-cmt>
     <transl>Unicode 版本</transl>
    </text>
    <text id="InTech">
     <orig>In technical documentation</orig>
     <au-cmt>Test: bidi info</au-cmt>
     <transl>在技术文档中</transl>
    </text>
    <text id="Block">
     <orig>Block</orig>
     <au-cmt>Any char</au-cmt>
     <transl>区块</transl>
    </text>
    <text id="Script">
     <orig>Script</orig>
     <au-cmt>Test: Any char w/script (e.g. A)</au-cmt>
     <transl>文字</transl>
    </text>
    <text id="Type">
     <orig>Type</orig>
     <au-cmt>Test: any char</au-cmt>
     <transl>类型</transl>
    </text>
    <text id="Bidi">
     <orig>In bidirectional writing</orig>
     <au-cmt>Test: any char</au-cmt>
     <transl>书写方向</transl>
    </text>
    <text id="Computers">
     <orig>Computers</orig>
     <au-cmt>Test: any char from Legacy computing</au-cmt>
     <transl>计算机</transl>
    </text>
    <text id="Dir">
     <orig>Direction</orig>
     <au-cmt>Test: Any script except Braille and technical</au-cmt>
     <transl>方向</transl>
    </text>
    <text id="Langs">
     <orig>Languages</orig>
     <au-cmt>Test: Any script except few technical</au-cmt>
     <transl>语言</transl>
    </text>
    <text id="Appear">
     <orig>Appeared</orig>
     <au-cmt>Test: Any script except few technical</au-cmt>
     <transl>出现</transl>
    </text>
    <text id="Condition">
     <orig>Status</orig>
     <au-cmt>
      <p>Maybe status</p>
      <p>Test: any live (or previously live) script</p>
     </au-cmt>
     <transl>状态</transl>
    </text>
    <text id="Plane">
     <orig>Plane</orig>
     <au-cmt>Test: any script</au-cmt>
     <transl>平面</transl>
    </text>
    <text id="base">
     <orig>Base</orig>
     <au-cmt>Test: props of any base plane script</au-cmt>
     <transl>基础</transl>
    </text>
    <text id="Utf8">
     <orig>UTF-8</orig>
     <au-cmt>Test: any char</au-cmt>
     <transl>UTF-8</transl>
    </text>
    <text id="Utf16">
     <orig>UTF-16</orig>
     <au-cmt>Test: any char</au-cmt>
     <transl>UTF-16</transl>
    </text>
    <text id="Utf32">
     <orig>UTF-32</orig>
     <transl>UTF-32</transl>
    </text>
    <text id="Html">
     <orig>HTML</orig>
     <au-cmt>Test: any char</au-cmt>
     <transl>HTML</transl>
    </text>
    <text id="AllVer">
     <orig>All characters are in Unicode version</orig>
     <transl>所有字符都在 Unicode 版本中</transl>
    </text>
    <text id="EmojiVer">
     <orig>Approved in emoji version</orig>
     <transl>在表情符号版本核准</transl>
    </text>
    <text id="EmojiV">
     <orig>Emoji {1}</orig>
     <au-cmt>See in old emoji of Library</au-cmt>
     <transl>表情符号 {1}</transl>
    </text>
    <text id="EmojiV2">
     <orig>=Unicode {1}, </orig>
     <au-cmt>See in old emoji of Library, space afterwards!</au-cmt>
     <transl>= Unicode {1}，</transl>
    </text>
    <text id="EmojiVA">
     <orig>≈Unicode {1}, </orig>
     <au-cmt>See in old emoji of Library, space afterwards!</au-cmt>
     <transl>≈ Unicode {1}，</transl>
    </text>
    <text id="CameAfter">
     <orig>, after Unicode {1}</orig>
     <transl>，在Unicode {1} 之后</transl>
    </text>
    <text id="Extend">
     <orig>Extended</orig>
     <au-cmt>As of U16, three blocks were extended: Tibt, Ahom, Egyp controls</au-cmt>
     <transl>扩展</transl>
    </text>
    <text id="Shrunk">
     <orig>Shrunk</orig>
     <au-cmt>As of U16, one block was shrunk: Tang supp</au-cmt>
     <transl>缩减</transl>
    </text>
    <text id="Brk">
     <orig>Line breaking</orig>
     <transl>换行</transl>
    </text>
   </group>
   <group id="Os">
    <au-cmt>Test: OS style (2nd character box, instead of font name)</au-cmt>
    <text id="Invisible">
     <orig>(Invisible)</orig>
     <transl>（不可见）</transl>
    </text>
    <text id="Tofu">
     <orig>(Absent in system)</orig>
     <transl>（系统中缺失）</transl>
    </text>
    <text id="NonChar">
     <orig>(Non-character)</orig>
     <transl>（非字符）</transl>
    </text>
    <text id="Empty">
     <orig>(Vacant position)</orig>
     <transl>（空位置）</transl>
    </text>
    <text id="FontsFor">
     <orig>Fonts for U+%04X</orig>
     <au-cmt>Test: some char (better Latin), click font name (=OS style)</au-cmt>
     <transl>U+%04X 字体</transl>
    </text>
    <text id="Style">
     <orig>(OS style)</orig>
     <transl>（操作系统风格）</transl>
    </text>
   </group>
   <group id="Life">
    <text id="Alive">
     <orig>alive ''(no threats to the main language, like Cyrillic)''</orig>
     <transl>使用中（稳定的主要语言，如：西里尔文字）</transl>
    </text>
    <text id="Danger">
     <orig>endangered due to language ''(like Cherokee)''</orig>
     <transl>因语言而濒危（如：切罗基文字）</transl>
    </text>
    <text id="Competing">
     <orig>endangered due to script competition ''(like Tai Tham)''</orig>
     <transl>因文字竞争而濒危（如：西双版纳老傣文字）</transl>
    </text>
    <text id="Dead">
     <orig>dead ''(will lose soon/recently lost users, like Nüshu)''</orig>
     <transl>已废弃（即将或最近失去使用者，如：女书）</transl>
    </text>
    <text id="Sacred">
     <orig>religious ''(dead in secular use, like Coptic)''</orig>
     <transl>宗教性（世俗使用中已消失，如：科普特文字）</transl>
    </text>
    <text id="New">
     <orig>new ''(appeared recently, like N’Ko)''</orig>
     <transl>新（最近出现，如：西非书面文字）</transl>
    </text>
    <text id="Reborn">
     <orig>revived ''(like Tifinagh)''</orig>
     <transl>复兴（如：提非纳文字）</transl>
    </text>
    <text id="Exp">
     <orig>experimental ''(attempt to make a new script for existing language, like Deseret)''</orig>
     <transl>实验性（为现有语言创造新书写体系的尝试，如：德瑟雷特文字）</transl>
    </text>
    <text id="Conserved">
     <orig>historical, no decipherment needed ''(like Glagolitic)''</orig>
     <transl>历史性的，无需解读（如：格拉哥里文字）</transl>
    </text>
    <text id="Undeciphered">
     <orig>undecipered ''(like Linear A)''</orig>
     <transl>未解读（如：线形文字 A）</transl>
    </text>
    <text id="Partly">
     <orig>partly deciphered ''(like Carian)''</orig>
     <transl>部分解读（如：卡里亚文字）</transl>
    </text>
    <text id="Deciphered">
     <orig>deciphered ''(like cuneiform)''</orig>
     <transl>解读（如：楔形文字）</transl>
    </text>
    <text id="ForRev">
     <orig>made to revive a dead language ''(like Osage)''</orig>
     <transl>为恢复消亡语言而设计（如：欧塞奇文字）</transl>
    </text>
   </group>
   <group id="Dir">
    <text id="L">
     <orig>→</orig>
     <au-cmt>Test: any LTR script, e.g. Latin</au-cmt>
     <transl>→</transl>
    </text>
    <text id="R">
     <orig>←</orig>
     <au-cmt>Test: any RTL script, eg Arabic, Hebrew</au-cmt>
     <transl>←</transl>
    </text>
    <text id="L_cjk">
     <orig>→ ''(historically ←↓↓ in columns)''</orig>
     <au-cmt>Test: any CJK script: Hani, Nshu</au-cmt>
     <transl>→ ''（历史上 ←↓↓ 列）''</transl>
    </text>
    <text id="L_cunei">
     <orig>←↓↓ in columns, then →</orig>
     <au-cmt>Test: cuneiform</au-cmt>
     <transl>←↓↓ 列，然后 →</transl>
    </text>
    <text id="L_ogam">
     <orig>→, ↑</orig>
     <au-cmt>Test: Ogam</au-cmt>
     <transl>→，↑</transl>
    </text>
    <text id="L_col">
     <orig>↓↓→ in columns</orig>
     <au-cmt>Test: Mong, Ougr, Phag</au-cmt>
     <transl>↓↓→ 列</transl>
    </text>
    <text id="L_most">
     <orig>mostly →</orig>
     <au-cmt>Test: Runr</au-cmt>
     <transl>大部分 →</transl>
    </text>
    <text id="TD">
     <orig>↓</orig>
     <au-cmt>Test: Sgnw</au-cmt>
     <transl>↓</transl>
    </text>
    <text id="Both">
     <orig>wrote both ← and →</orig>
     <au-cmt>Test: Cari, Egyp, Ital</au-cmt>
     <transl>写 ← 和 → 两者</transl>
    </text>
    <text id="R_col">
     <orig>←↓↓ in columns</orig>
     <au-cmt>Test: Kits, Mero</au-cmt>
     <transl>←↓↓ 列</transl>
    </text>
    <text id="R_most">
     <orig>mostly ←</orig>
     <au-cmt>Test: Cprt, Lydi, Sarb</au-cmt>
     <transl>大部分 ←</transl>
    </text>
    <text id="Sogd">
     <orig>↓↓→ in columns; ←</orig>
     <au-cmt>Test: Sogd (new!), Chrs</au-cmt>
     <transl>↓↓→ 列； ←</transl>
    </text>
   </group>
   <group id="Type">
    <text id="Alph">
     <orig>[[pt:alphabet|alphabetic]]{{-}}''like Cyrillic''</orig>
     <transl>[[pt:alphabet|字母]]（如：西里尔文字）</transl>
    </text>
    <text id="Argu">
     <orig>[[pt:arguable|arguable]]{{-}}''like Thaana''</orig>
     <transl>[[pt:arguable|有争议的]]（如：它拿文字）</transl>
    </text>
    <text id="Cons">
     <orig>[[pt:abjad|consonant]]{{-}}''like Hebrew''</orig>
     <transl>[[pt:abjad|辅音]]（如：希伯来文字）</transl>
    </text>
    <text id="Syll">
     <orig>[[pt:syllabic|syllabic]]{{-}}''like Japanese Katakana/Hiragana''</orig>
     <transl>[[pt:音节文字|音节]]（如：日语片假名/平假名）</transl>
    </text>
    <text id="Asyl">
     <orig>alphasyllabic{{-}}''like Old Persian cuneiform''</orig>
     <transl>字母音节混合型（如：古波斯楔形文字）</transl>
    </text>
    <text id="Abug">
     <orig>[[pt:abugida|abugida]]{{-}}''like Ethiopic''</orig>
     <transl>[[pt:abugida|元音附标文字]]（如：埃塞俄比亚文字）</transl>
    </text>
    <text id="Brah">
     <orig>[[pt:brahmic|Brahmic abugida]]{{-}}''like Devanagari''</orig>
     <transl>[[pt:brahmic|婆罗米系元音附标文字]]（如：天城文字）</transl>
    </text>
    <text id="Hier">
     <orig>[[pt:hiero|ideographic]]{{-}}''like CJK ideographs''</orig>
     <transl>[[pt:hiero|表意文字]]（如：中日韩表意文字）</transl>
    </text>
    <text id="Syhi">
     <orig>ideosyllabic{{-}}''like Linear B''</orig>
     <transl>表音节（如：线形文字 B）</transl>
    </text>
    <text id="Cohi">
     <orig>ideoconsonant{{-}}''like Egyptian hieroglyphs''</orig>
     <transl>表辅音（如：埃及象形文字）</transl>
    </text>
    <text id="Code">
     <orig>[[pt:code|codes and shorthand]]{{-}}''like Braille embossings''</orig>
     <transl>[[pt:code|代码和速记]]（如：盲文压印）</transl>
    </text>
    <text id="Nota">
     <orig>[[pt:nontext|non-text]]{{-}}''like musical notes''</orig>
     <au-cmt>Test: Sgnw</au-cmt>
     <transl>[[pt:nontext|非文本]]（如：音乐记号）</transl>
    </text>
   </group>
   <group id="Kx">
    <au-cmt>CJK Kangxi radical, maintained by Unicode themselves</au-cmt>
    <text id="Bullet">
     <orig>Radical</orig>
     <au-cmt>Link will be auto-added</au-cmt>
     <transl>部首</transl>
    </text>
    <text id="Data">
     <orig>{1} {2} {3|one=# stroke|many=# strokes}</orig>
     <au-cmt>1=radical, 2=±, 3=# of strokes</au-cmt>
     <transl>{1} {2} {3} 画</transl>
    </text>
   </group>
   <group id="Ver">
    <text id="Ext">
     <orig>Extended</orig>
     <transl>扩展</transl>
    </text>
    <text id="Shr">
     <orig>Shrunk</orig>
     <transl>缩减</transl>
    </text>
   </group>
   <group id="Lang">
    <group id="Num">
     <text id="Unit">
      <orig>{1} people</orig>
      <au-cmt>Specially for Toto</au-cmt>
      <transl>{1} 人</transl>
     </text>
     <text id="Tho">
      <orig>{1}k</orig>
      <transl>{1} 千</transl>
     </text>
     <text id="Mil">
      <orig>{1}M</orig>
      <transl>{1} 百万</transl>
     </text>
     <text id="Bil">
      <orig>{1}bn</orig>
      <transl>{1} 亿</transl>
     </text>
    </group>
    <text id="Qty">
     <orig>{1} as of {2}</orig>
     <transl>截至 {2} 为 {1}</transl>
    </text>
    <text id="QtyNative">
     <orig>{1} native speakers as of {2}</orig>
     <transl>截至 {2} 母语使用者为 {1}</transl>
    </text>
    <text id="QtyIndia">
     <orig>{1} in India as of {2}</orig>
     <au-cmt>Test: Nag</au-cmt>
     <transl>截至 {2} 印度地区为 {1}</transl>
    </text>
    <text id="QtyTotal">
     <orig>total {1} as of {2}</orig>
     <au-cmt>Test: Ethi A, Gamo-Gofa-Dawro</au-cmt>
     <transl>截至 {2} 年共计 {1}</transl>
    </text>
    <text id="QtyDecade">
     <orig>{1} as of {2}s</orig>
     <au-cmt>Test: Cakm, Gong, Guru, Limb…</au-cmt>
     <transl>{2} 年代统计为 {1}</transl>
    </text>
    <text id="QtyDecadeNative">
     <orig>{1} native speakers as of {2}s</orig>
     <au-cmt>Test: Arab only</au-cmt>
     <transl>{2} 年代母语使用者为 {1}</transl>
    </text>
   </group>
   <group id="LangLoc">
    <text id="AfricaC">
     <orig>Central Africa</orig>
     <au-cmt>U17 Beria Erfe</au-cmt>
     <transl>中非</transl>
    </text>
    <text id="AfricaW">
     <orig>Western Africa</orig>
     <au-cmt>Garay</au-cmt>
     <transl>西非</transl>
    </text>
    <text id="Bangladesh">
     <orig>Bangladesh</orig>
     <transl>孟加拉国</transl>
    </text>
    <text id="Bhutan">
     <orig>Bhutan</orig>
     <transl>不丹</transl>
    </text>
    <text id="Cambodia">
     <orig>Cambodia</orig>
     <au-cmt>Cham</au-cmt>
     <transl>柬埔寨</transl>
    </text>
    <text id="China">
     <orig>China</orig>
     <transl>中国</transl>
    </text>
    <text id="ChinaSw">
     <orig>South-Western China</orig>
     <transl>中国西南部</transl>
    </text>
    <text id="Ethiopia">
     <orig>Ethiopia</orig>
     <transl>埃塞俄比亚</transl>
