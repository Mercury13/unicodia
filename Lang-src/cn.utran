  <group id="Lib">
   <group id="Group">
    <text id="Strange">
     <orig>Strange CJK ideographs</orig>
     <transl>生僻中日韩表意文字</transl>
    </text>
    <text id="A">
     <orig>A: asymmetric</orig>
     <transl>A：不对称</transl>
    </text>
