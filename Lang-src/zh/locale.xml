<?xml version="1.0" encoding="UTF-8" ?>
<locale native="汉语" international="Chinese" eng-terms="1">
	<debug ini="" />
	<trigger-langs stamp="2026040">
		<lang iso="zh" />
	</trigger-langs>
	<!-- Sorting Rules:
		1. Digits < Latin letters < Japanese / Cyrillic < Symbols < Chinese characters
		2. Compare character by character according to Pinyin: a < b < c < ... < z (case-insensitive)
		3. For homophones (same letters): sort by tone, e.g., 妈 (mā) < 麻 (má) < 马 (mǎ) < 骂 (mà) < 吗 (ma)
		4. For homophones with the same tone: sort by stroke count (ascending). 
			For characters with the same stroke count: sort by initial stroke type: horizontal (一) < vertical (丨) < left-falling (丿) < dot (丶) < turning (乛)
		5. For characters with identical stroke forms: sort by character
			structure: left-right structure < top-bottom structure < enclosed / miscellaneous structure
		6. Special handling: ü is transcribed as u; for polyphonic characters, use their most common pronunciation
	 -->
	<alpha-sort>
		<alp>ABCDEFGHIJKLMNOPQRSTUVWXYZ</alp>
		<alp>abcdefghijklmnopqrstuvwxyz</alp>
		<alp>____________________Ü_____</alp>
		<alp>____________________ü_____</alp>
		<alp follow="1" />
		<alp>阿埃爱安奥八巴拜半包碑北贝本彼变标表波</alp>
		<alp follow="1" />
		<alp>柏补布查创尔达傣代德低底帝杜多方非腓吠</alp>
		<alp follow="1" />
		<alp>费符甘高哥格古贡光国哈汉洪花回货基及吉</alp>
		<alp follow="1" />
		<alp>几加假箭交旧卡凯康科可克控库扩拉兰老勒</alp>
		<alp follow="1" />
		<alp>雷里利傈炼林隆卢鲁吕麻马玛麦曼盲梅门蒙</alp>
		<alp follow="1" />
		<alp>孟米缅摩莫默木穆纳乃南尼女努欧帕片平婆</alp>
		<alp follow="1" />
		<alp>扑浦奇棋契切佉钦撒萨桑塞僧上声诗竖数私</alp>
		<alp follow="1" />
		<alp>斯苏速粟算索它他塔唐太泰特提天通统投图</alp>
		<alp follow="1" />
		<alp>突托瓦万望围维挝乌西希悉锡夏线萧小楔型</alp>
		<alp follow="1" />
		<alp>匈叙巽雅亚谚伊彝易意音印永越杂藏早札占</alp>
		<alp follow="1" />
		<alp>制兹字中注爪篆装组</alp>
	</alpha-sort>
	<alpha-fixup />
	<ellipsis text="…">
		<blk start="1AB0"  /><!-- umlauts supp. It’s the 3rd in cluster; 2 and 4 do not need -->
		<blk start="2E00"  /><!-- supp punctuation -->
		<blk start="2E80"  /><!-- CJK radicals supplement -->
		<blk start="30A0"  /><!-- Katakana -->
		<blk start="31F0"  /><!-- Katakana phonetic -->
		<blk start="10100" /><!-- Aegean numbers -->
		<blk start="10140" /><!-- Ancient Greek numbers -->
		<blk start="10F00" /><!-- Old Sogdian -->
		<blk start="11B60" /><!-- Sharada supp, until localized -->
		<blk start="12480" /><!-- Early dynastic cuneiform -->
		<blk start="18D80" /><!-- Tangut components supp, until localized -->
		<blk start="1AFF0" /><!-- Kana extended-B -->
		<blk start="1B000" /><!-- Kana supplement -->
		<blk start="1B100" /><!-- Kana extended-A -->
		<blk start="1B130" /><!-- Small kana extension -->
		<blk start="1BCA0" /><!-- Shorthand format controls -->
		<blk start="1CEC0" /><!-- sym misc supp, until localized -->
		<blk start="1D200" /><!-- Ancient Greek music notation -->
		<blk start="1F900" /><!-- Sym ex -->
		<blk start="1FA70" /><!-- Sym ex A -->
	</ellipsis>
	<!-- You can make any wiki templates (w/o params) you want. Maybe you’d like to enclose them in CDATA. -->
	<wiki-templates>
		<!-- first{{-}}second  →  typographic dash -->
		<tmpl name="-"><![CDATA[<span style='font-size:4pt'>&#xA0;</span>—<span style='font-size:4pt'> </span>]]></tmpl>
		<!-- first{{,-}}second  →  typographic comma-dash -->
		<tmpl name=",-"><![CDATA[,—<span style='font-size:4pt'> </span>]]></tmpl>
	</wiki-templates>
	<design hiero-bigger="1">
		<icons sort-az="sort_cn" />
	</design>
	<num-format dec-point="." thou-point=" " thou-min-length="4" thou-min-length-dense="5">
		<imprecise>
			<fmt shift="0" text="{1} 人" frac="never" />
			<fmt shift="3" text="{1} 千人" frac="avoid" />
			<fmt shift="4" text="{1} 万人" frac="prefer" />
			<fmt shift="8" text="{1} 亿人" frac="prefer" />
		</imprecise>
		<moreless less="{1}以下" more="{1}以上" phase="unit" />
		<percent inverse="0" space="1" />
	</num-format>
	<!-- Chinese has no rules for cardinal plurals -->
	<cardinal-rules default-outcome="other" />
	<ordinal-rules />
	<peculiarities still-uses-burmese="0" hiero-bigger="1" />
	<punctuation key-value-colon="：" uniform-comma="，" semicolon="；"
			left-paren="（" right-paren="）" indent-ellip="……"
			range="…" year-range="—" to=" →" />
	<rename-altcode />
</locale>
