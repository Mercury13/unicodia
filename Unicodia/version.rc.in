#include <winver.h>

VS_VERSION_INFO VERSIONINFO
 FILEVERSION @VERSION_COMMA@
 PRODUCTVERSION @VERSION_COMMA@
 FILEFLAGSMASK 0x3fL
 FILEFLAGS 0x0L
 FILEOS 0x40004L
 FILETYPE 0x1L
 FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "FileDescription", "Unicodia: encyclopedia of characters\0"
            VALUE "FileVersion", "@VERSION_STR@\0"
            VALUE "ProductVersion", "@VERSION_STR@\0"
            VALUE "CompanyName", "Mikhail Merkuryev\0"
            VALUE "LegalCopyright", "Mikhail Merkuryev\0"
            VALUE "ProductName", "Unicodia\0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 1200
    END
END